# =============================================================================
# RetrievalLab — .env.example
# =============================================================================
# PURPOSE : Documents every environment variable the application uses.
#           Copy this file to .env and fill in real values.
#           NEVER commit .env to git — it is in .gitignore.
#
# SETUP:
#   cp .env.example .env
#   # Then edit .env with your real API keys and config.
#
# NOTES:
#   • All variables with "your_*" values MUST be replaced before running.
#   • Variables with default values work as-is for local Docker Compose setup.
#   • See docs/configuration.md for detailed explanation of each variable.
# =============================================================================

# ─── Application ─────────────────────────────────────────────────────────────
APP_NAME=RetrievalLab
APP_ENV=development          # development | staging | production
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000
SECRET_KEY=LetsMakeASecretKeyMSIS_2026!Secure9xP4

# ─── PostgreSQL ──────────────────────────────────────────────────────────────
# These match the values in docker-compose.yml for local dev.
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=retrievallab
POSTGRES_USER=retrievallab
POSTGRES_PASSWORD=retrievallabdevpassword
DATABASE_URL=postgresql+asyncpg://retrievallab:retrievallab_dev_password@localhost:5432/retrievallab

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=                # empty = no auth (fine for local dev)
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ─── MinIO (S3-compatible local object storage) ──────────────────────────────
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_NAME=retrievallab
MINIO_SECURE=false            # true in production (HTTPS)

# ─── ChromaDB ────────────────────────────────────────────────────────────────
CHROMA_HOST=localhost
CHROMA_PORT=8001
CHROMA_COLLECTION_PREFIX=rl_  # all collections prefixed to avoid collisions

# ─── Elasticsearch ───────────────────────────────────────────────────────────
ELASTICSEARCH_URL=http://localhost:9200
ELASTICSEARCH_INDEX_PREFIX=rl_

# ─── LLM Providers ───────────────────────────────────────────────────────────
# IMPORTANT: Get these from each provider's dashboard.
ANTHROPIC_API_KEY=your_anthropic_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
COHERE_API_KEY=your_cohere_api_key_here

# Default models (can be overridden per-experiment via YAML config)
DEFAULT_LLM_PROVIDER=anthropic
DEFAULT_CHAT_MODEL=claude-3-5-haiku-20241022
DEFAULT_EMBED_MODEL=text-embedding-3-small

# ─── Embedding Cache ─────────────────────────────────────────────────────────
EMBED_CACHE_TTL_SECONDS=86400   # 24 hours
EMBED_CACHE_MAX_SIZE_MB=500

# ─── Chunking Defaults ───────────────────────────────────────────────────────
DEFAULT_CHUNK_SIZE=512          # tokens
DEFAULT_CHUNK_OVERLAP=64        # tokens
DEFAULT_CHUNK_STRATEGY=recursive

# ─── Retrieval Defaults ──────────────────────────────────────────────────────
DEFAULT_TOP_K=10
DEFAULT_RETRIEVER=hybrid        # sparse | dense | hybrid

# ─── MLflow ──────────────────────────────────────────────────────────────────
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_EXPERIMENT_NAME=retrievallab_default

# ─── Observability ───────────────────────────────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=retrievallab-api
PROMETHEUS_PORT=9090

# ─── Logging ─────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO                  # DEBUG | INFO | WARNING | ERROR
LOG_FORMAT=json                 # json | pretty (use pretty for local dev)
